# --- App Configuration ---
APP_NAME=FoOdyssey API
APP_ENV=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# --- Server Configuration ---
# (Used in local development without Docker)
UVICORN_HOST=127.0.0.1
UVICORN_PORT=8000

# --- Database Configuration ---
# Format: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg://foodyssey:foodyssey@localhost:5432/foodyssey

# --- Cache Configuration ---
FILTERS_CACHE_TTL_SECONDS=300

# --- AI Configuration (Groq) ---
# Get your API key from https://console.groq.com/
GROQ_API_KEY=

# --- Authentication (Supabase) ---
# Your Supabase Project JWT Secret (Settings -> API)
SUPABASE_JWT_SECRET=
SUPABASE_JWT_ALGORITHM=HS256

# --- Maps Configuration (Google) ---
# Optional: Used for real distance/ETA calculation. Fallback to mock if empty.
GOOGLE_MAPS_API_KEY=
