# ==============================================================================
# FRONTEND CONFIGURATION
# ==============================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Map (Phase 1 — clean map / compliance)
# Default provider: osm (raster). Basemap tiles default to Carto Voyager in code.
NEXT_PUBLIC_MAP_PROVIDER=osm

# Goong vector basemap — only when NEXT_PUBLIC_MAP_PROVIDER=goong AND key is set.
NEXT_PUBLIC_GOONG_MAPTILES_KEY=

# ==============================================================================
# BACKEND CONFIGURATION
# ==============================================================================
APP_NAME=FoOdyssey API
APP_ENV=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Database URL for Docker Compose (Postgres service name)
DATABASE_URL=postgresql+psycopg://foodyssey:foodyssey@postgres:5432/foodyssey

# Cache Configuration
FILTERS_CACHE_TTL_SECONDS=300

# AI Configuration (Groq)
GROQ_API_KEY=

# Authentication (Supabase)
SUPABASE_JWT_SECRET=
SUPABASE_JWT_ALGORITHM=HS256

# Maps Configuration (Google)
GOOGLE_MAPS_API_KEY=

# ==============================================================================
# INFRASTRUCTURE (DOCKER)
# ==============================================================================
POSTGRES_DB=foodyssey
POSTGRES_USER=foodyssey
POSTGRES_PASSWORD=foodyssey
