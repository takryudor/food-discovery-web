# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Map (Phase 1 — clean map / compliance)
# Default provider: osm (raster). Basemap tiles default to Carto Voyager in code (see mapConfig.ts).
NEXT_PUBLIC_MAP_PROVIDER=osm
# Default (Carto Voyager) — re-test sea area for map compliance before production.
# NEXT_PUBLIC_MAP_TILE_URL=https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png
# NEXT_PUBLIC_MAP_ATTRIBUTION=&copy; OpenStreetMap contributors &copy; CARTO

# Goong vector basemap — only when NEXT_PUBLIC_MAP_PROVIDER=goong AND key is set.
# Audit for map compliance (nine-dash line) before enabling in production.
# https://account.goong.io/keys
NEXT_PUBLIC_GOONG_MAPTILES_KEY=

# Backend
APP_NAME=FoOdyssey API
APP_ENV=development
API_V1_PREFIX=
DATABASE_URL=postgresql+psycopg://foodyssey:foodyssey@postgres:5432/foodyssey
CORS_ORIGINS=["http://localhost:3000"]

# PostgreSQL
POSTGRES_DB=foodyssey
POSTGRES_USER=foodyssey
POSTGRES_PASSWORD=foodyssey
